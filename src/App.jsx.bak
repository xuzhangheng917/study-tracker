const GITHUB_REPO = 'xuzhangheng917/study-tracker'
const RELEASE_API = `https://api.github.com/repos/${GITHUB_REPO}/releases/latest`
const RELEASE_URL = `https://github.com/${GITHUB_REPO}/releases/latest`

